/* pages/logsDetail/logsDetail.wxss */
.container {
  padding: 30rpx;
  background: #fff;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
  word-break: break-all;
}

.meta {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 30rpx;
}

.content-block {
  margin-bottom: 40rpx;
}

.content {
  font-size: 28rpx;
  line-height: 1.6;
  display: block;
  white-space: pre-wrap;
  word-break: break-word;
  color: #555;
}

.inline-image-container {
  display: flex;
  justify-content: center;
  margin: 30rpx 0;
}

.inline-image {
  width: 90%;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

/* 附加图区域 */
.images-section {
  margin-top: 20rpx;
}

.append-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.grid-item {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1 / 1;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.grid-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}