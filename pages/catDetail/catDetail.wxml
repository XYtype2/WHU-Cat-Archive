<view style="display:flex; justify-content:center; align-items:center;">
  <image mode="widthFix" bindtap='previewImage' class="cat_image" data-src="{{url}}{{cat.name}}.jpg" src="{{url}}{{cat.name}}.jpg" style="width: 90%;">
  </image>
</view>

<view class="itemname1" style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
  <view style='flex-shrink:0; box-sizing:border-box; width:350rpx; display: flex; align-items: center;'>
    <view class="cat-card">{{cat.name}}</view>
  </view>

  <view style="display: flex; align-items: center;">

    <!-- 送礼区域：图标 + 下方 "+" -->
    <!-- <view style="display: flex; flex-direction: column; align-items: center; margin-right: -10rpx;">
      <view bindtap="openGiftPanel" style="background: transparent; border: none; padding: 16rpx; cursor: pointer;">
        <image src="https://whutnr-1311545081.cos.ap-guangzhou.myqcloud.com/picture/gift.png" style="width: 36rpx; height: 36rpx;"></image>
      </view>
      <text style="font-size: 30rpx; color: #666; margin-top: -30rpx;">+</text>
    </view> -->

    <!-- 点赞区域：图片爱心 + 数字 -->
    <view style="display: flex; flex-direction: column; align-items: center; margin-right: 40rpx;">
      <view bindtap="likeCat" style="background: transparent; border: none; padding: 16rpx; cursor: pointer;">
        <image 
          src="{{hasLiked ? 'https://whutnr-1311545081.cos.ap-guangzhou.myqcloud.com/picture/liked.png' : 'https://whutnr-1311545081.cos.ap-guangzhou.myqcloud.com/picture/like.png'}}" 
          style="width: 36rpx; height: 34rpx;"
        ></image>
      </view>
      <text style="font-size: 24rpx; color: #666; margin-top: -24rpx;">{{likeCount}}</text>
    </view>

  </view>
</view>

<view class="itemname1">
