<view wx:if="{{relatedCatsId}}" class="itemname1">
  <navigator style='margin-right:20rpx;' wx:for="{{relatedCatsId}}" wx:key="_id" url="/pages/catDetail/catDetail?_id={{relatedCatsId[index]._id}}">
    <view style='flex-shrink:0; box-sizing:border-box; width:90rpx;'>
      <image style="margin-top: 10rpx; width:90rpx;height:90rpx;" src="{{url}}{{relatedCatsId[index].name}}.png"></image>
      <view style="text-align: center; margin-bottom: 40rpx; color:#353535;"> \n {{relatedCatsId[index].name}} </view>
    </view>
  </navigator>
</view>

<text> \n </text>

<block wx:for="{{photoArray}}" wx:key="_id">
  <view style="display:flex; justify-content:center; align-items:center;">
    <image mode="widthFix" class="cat_image" bindtap='previewImage' src="{{url}}{{cat.name}}{{photoArray[index]}}.jpg" data-src="{{url}}{{cat.name}}{{photoArray[index]}}.jpg" style="width: 90%;">
    </image>
  </view>
  <text> \n </text>
</block>

<block wx:for="{{MovieNums}}" wx:key="_id">
  <view style="display:flex; justify-content:center; align-items:center;">
    <video mode="widthFix" class="cat_image" src="{{url}}{{cat.name}}{{item.num}}.mp4" style="width: 90%;">
    </video>
  </view>
  <text> \n </text>
</block>

<view wx:if="{{cat.photographer !== undefined}}" 
      class="photographer-block" 
      style="margin-top: -40rpx; margin-bottom: 60rpx; text-align: center; padding-bottom: env(safe-area-inset-bottom);">
  <text style="color: #888; font-size: 20rpx;">
    照片拍摄者（按小头像、首图和附加图顺序排列）：
  </text>
  <view style="margin-top: -50rpx;">
    <text style="color: #888; font-size: 20rpx; font-weight: 500;">
      {{cat.photographer || '（未知）'}}
    </text>
  </view>
</view>

<!-- 主送礼面板 -->
<view 
  wx:if="{{showGiftPanel}}" 
  style="position: fixed; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.6); z-index: 999; display: flex; justify-content: center; align-items: center;"
  bindtap="closeAllPanels" >
  <view 
    style="background: white; width: 90%; padding: 40rpx 20rpx; border-radius: 20rpx; text-align: center; min-height: 280rpx;"
    catchtap
  >
    <view style="font-size: 30rpx; font-weight: bold; margin-bottom: 32rpx;">
      {{cat.name}}收到的礼物
    </view>

    <!-- 徽章横向排列：固定首位为“赠送礼物”，后面是真实徽章 -->
    <view style="display: flex; align-items: flex-start; gap: 24rpx; overflow-x: auto; padding: 10rpx 0; justify-content: flex-start;">
      <!-- 固定首位：赠送礼物 -->
      <view 
        style="display: flex; flex-direction: column; align-items: center; flex-shrink: 0;"
        bindtap="openBackpackPanel"
      >
      <view style="width: 110rpx; height: 110rpx; border-radius: 50%; background: #f9e4a5; display: flex; justify-content: center; align-items: center;">
      <!-- <view style="width: 110rpx; height: 110rpx; border-radius: 50%; background: #ffffff;border: 4rpx solid #ffeaa7; display: flex; justify-content: center; align-items: center;box-sizing: border-box;"> -->
          <image src="https://whutnr-1311545081.cos.ap-guangzhou.myqcloud.com/picture/gift.png" style="width: 36rpx; height: 36rpx;"></image>
        </view>
        <text style="margin-top: 12rpx; font-size: 22rpx; color: #000000;">点击赠礼</text>
        <!-- <text class="shine-text" style="margin-top: 12rpx;">点击赠礼</text> -->
        <!-- <text class="bounce-text" style="margin-top: 12rpx;">赠送礼物</text> -->
      </view>


      <!-- 猫咪收到的真实徽章（从左到右） -->
      <view 
        wx:for="{{groupedBadges}}" 
        wx:key="badgeId"
        style="display: flex; flex-direction: column; align-items: center; flex-shrink: 0;"
        bindtap="showBadgeSenders"
        data-badgeid="{{item.badgeId}}"
      >
        <view style="width: 110rpx; height: 110rpx; border-radius: 50%; background: #f8f8f8; display: flex; justify-content: center; align-items: center; position: relative;">
          <!-- 动态徽章图片 -->
          <image 
            src="{{item.icon || '/pages/images/default_badge.png'}}" 
            style="width: 90rpx; height: 90rpx; border-radius: 50%;"
          ></image>
          <!-- 数量角标 -->
          <view style="position: absolute; bottom: -8rpx; right: -8rpx; background: #ff6b6b; color: white; border-radius: 50%; width: 36rpx; height: 36rpx; display: flex; justify-content: center; align-items: center; font-size: 20rpx;">
            {{item.count}}
          </view>
        </view>
        <text style="margin-top: 12rpx; font-size: 22rpx;">{{item.name || '徽章'}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 背包面板（带遮罩） -->
<view 
  wx:if="{{showBackpackPanel}}" 
  style="position: fixed; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.6); z-index: 1000; display: flex; justify-content: center; align-items: flex-end;"
  bindtap="closeBackpackPanel" 
>
  <view 
    style="background: white; width: 100%; max-height: 70vh; border-top-left-radius: 24rpx; border-top-right-radius: 24rpx; padding: 30rpx; box-sizing: border-box; display: flex; flex-direction: column;"
    catchtap
  >
    <!-- 头部 -->
    <view style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx;">
      <text style="font-size: 32rpx; font-weight: bold;">我的礼物</text>
      <view bindtap="closeBackpackPanel" style="font-size: 30rpx; color: #999;">×</view>
    </view>

  <!-- 背包内容区域（可滚动） -->
  <view style="flex: 1; overflow-y: auto; margin-bottom: 24rpx;">
    <block wx:if="{{loadingBackpack}}">
      <view style="text-align: center; padding: 40rpx;">加载中...</view>
    </block>
    <block wx:elif="{{userBackpack.length === 0}}">
      <view style="text-align: center; color: #888; margin: 60rpx 0;">
        背包空空如也
      </view>
    </block>
    <view wx:else style="display: flex; flex-wrap: wrap; gap: 6rpx;">
      <view 
        wx:for="{{userBackpack}}" 
        wx:key="badgeId"
        style="width: calc(20% - 6rpx); display: flex; flex-direction: column; align-items: center;"
        data-badgeid="{{item.badgeId}}"
        bindtap="selectBadgeForSend"
      >
        <!-- 徽章图标容器 -->
        <view 
          style="width: 120rpx; height: 120rpx; border-radius: 50%; background: #f8f8f8; display: flex; justify-content: center; align-items: center; position: relative; margin-bottom: 2rpx; border: 4rpx solid transparent; {{selectedBadgeId === item.badgeId ? 'border: 4rpx solid #cf1e1e;' : ''}}"
        >
          <image 
            src="{{item.icon || '/pages/images/default_badge.png'}}" 
            style="width: 100rpx; height: 100rpx; border-radius: 50%;"
          ></image>
          <!-- 数量角标 -->
          <view style="position: absolute; bottom: -4rpx; right: -4rpx; background: #ff6b6b; color: white; border-radius: 50%; width: 28rpx; height: 28rpx; display: flex; justify-content: center; align-items: center; font-size: 18rpx;">
            {{item.count}}
          </view>
        </view>
        <text style="font-size: 24rpx; text-align: center;">{{item.name || '徽章'}}</text>
      </view>
    </view>
  </view>

    <!-- 底部双按钮（并排） -->
    <view style="display: flex; gap: 20rpx;">
      <button 
        type="default"
        style="flex: 1; background-color: #999; color: white; border: none; border-radius: 12rpx; font-size: 26rpx;"
        bindtap="goToGashapon"
      >
        获取更多
      </button>
      <button 
        type="default"
        style="flex: 1; background-color: #cf1e1e; color: white; border: none; border-radius: 12rpx; font-size: 26rpx;"
        bindtap="confirmSendSelectedBadge"
        disabled="{{!selectedBadgeId}}"
      >
        赠送
      </button>
      
    </view>
  </view>
</view>