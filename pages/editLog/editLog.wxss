.container {
  padding: 30rpx;
  box-sizing: border-box;
}

.input-title, .input-author, .input-tags {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea-content {
  width: 100% !important;
  height: 600rpx !important;
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.btn-save, .btn-delete, .btn-upload {
  width: 100%;
  height: 80rpx;
  background: #1890ff;
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.btn-delete {
  background: #ff4d4f;
}

.upload-section {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  color: #666;
  font-size: 26rpx;
  margin-bottom: 10rpx;
}

.preview-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-top: 10rpx;
}

.img-preview-row {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.preview-img-small {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.img-name {
  font-size: 24rpx;
  color: #888;
}

/* 九宫格容器 */
.grid-container {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

/* 单个图片项 */
.grid-item {
  position: relative;
  width: calc((100% - 20rpx) / 3); /* 3列 */
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.grid-img {
  width: 100%;
  height: 100%;
}

.grid-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  color: white;
  font-size: 20rpx;
  text-align: center;
  padding: 4rpx 0;
}

/* 预览图容器 */
.preview-container-small {
  position: relative;
  display: inline-block;
  margin-right: 20rpx;
}

/* 小预览图片样式 */
.preview-img-small {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-bottom: 5rpx; /* 给下面的按钮留出空间 */
}

/* 复制按钮样式 */
.btn-copy {
  font-size: 24rpx;
  background-color: #1890ff;
  color: white;
  padding: 5rpx 10rpx;
  border-radius: 8rpx;
  margin-top: 5rpx;
}