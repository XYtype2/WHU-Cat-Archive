.container {
  padding: 10rpx;
  background: #fff;
  min-height: 100vh;
  box-sizing: border-box;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}

.tip {
  text-align: center;
  color: #666;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

/* 二维码区 */
.qr-section {
  margin-bottom: 50rpx;
  text-align: center;
}

.qr-label {
  display: block;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #444;
}

.qr-code {
  width: 360rpx;
  margin: 0 auto;
  border-radius: 12rpx;
  background: #f9f9f9;
}

.qr-desc {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #888;
}

/* 链接区 */
.link-section {
  margin-bottom: 60rpx;
  text-align: center;
}

.link-label {
  display: block;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #444;
}

/* 可点击的链接框 */
.url-box {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #07c160; /* 绿色表示可点击 */
  word-break: break-all;
  display: inline-block; /* 让背景只包裹内容，且能居中 */
  max-width: 100%;
  box-sizing: border-box;
}

.url-box .copy-icon {
  margin-left: 12rpx;
  font-size: 28rpx;
}

/* 按下时的反馈（可选） */
.url-box:active {
  background: #e8f5ec;
}

/* 底部提示 */
.footer-tip {
  font-size: 24rpx;
  color: #555;
  text-align: center;
  line-height: 1.6;
}

.info-block {
  padding: 30rpx;          /* ⭐左右留白、上下留白 */
  margin: 20rpx;           /* 与周围保持间距 */
  background: #f8f8f8;      /* 微背景，柔和好看 */
  border-radius: 16rpx;     /* 圆角更温柔 */
  font-size: 26rpx;         /* 舒服的小字体 */
  color: #555;              /* 柔和的深灰色 */
  line-height: 1.6;         /* 让段落更好读 */
}

.line-space {
  height: 20rpx;
}


/* pages/catmap/index.wxss */
.container {
  width: 100%;
  height: 100vh;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  color: #666;
  font-size: 32rpx;
}

.map-container {
  width: 100%;
  height: 100%;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #f5f5f5;
}
.search-input {
  flex: 1;
  height: 60rpx;
  padding: 0 20rpx;
  border-radius: 30rpx;
  background: white;
  font-size: 28rpx;
}
.clear-btn {
  margin-left: 20rpx;
  width: 60rpx;
  height: 60rpx;
  font-size: 24rpx;
  line-height: 60rpx;
  padding: 0;
}

/* 中心点切换栏 */
.center-switch {
  display: flex;
  width: 90%; /* 变窄 */
  margin: 10rpx auto; /* 居中 */
  height: 60rpx;
  background: #f8f8f8;
  border-radius: 30rpx;
  overflow: hidden; /* 圆角裁剪子元素 */
}

.switch-item {
  flex: 1; /* 四等分 */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #333;
  /* 去掉所有边框、背景变化 */
  background: transparent;
  border: none;
  outline: none;
  user-select: none;
}

.switch-item:active {
  background: #e0e0e0; /* 点击时轻微反馈（可选） */
}

/* 无权限容器 */
.no-access-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
  min-height: 100vh;
  background-color: #f8f9fa;
}

/* 顶部提示文字 */
.no-access-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-bottom: 60rpx;
  text-align: center;
  line-height: 1.4;
}

/* 申请卡片 */
.apply-card {
  width: 100%;
  max-width: 600rpx;
  background: white;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.apply-card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.apply-card-desc {
  font-size: 26rpx;
  color: #777;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

/* 输入框 */
.apply-input {
  width: 100%;
  min-height: 72rpx; 
  padding: 20rpx 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

.apply-input::placeholder {
  color: #aaa;
}

/* 提交按钮 */
.apply-btn {
  width: 100%;
  height: 80rpx;
  background-color: #888;
  color: white;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(150, 163, 177, 0.3);
}

.apply-btn:disabled {
  background-color: #cccccc;
  color: #ffffff;
  box-shadow: none;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

/* 弹窗内容 */
.modal-content {
  background: #fff;
  width: 80%;
  max-height: 80%;
  border-radius: 20rpx;
  padding: 30rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20rpx;
}
.modal-title1 {
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 0rpx;
}
/* 猫列表区域 —— 明确指定宽度和避免内容溢出 */
.cat-list {
  width: calc(100% - 60rpx); /* 减去 modal-content 的 padding */
  max-height: 500rpx;
  overflow-y: auto;
  margin: 0 auto; /* 居中对齐 */
  box-sizing: border-box;
}

/* 每个猫选项 —— 简化布局 */
.cat-option {
  height: 80rpx;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #eee;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
}

.cat-name {
  text-align: center;
  /* 可选：限制单行 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 取消按钮 - 小号 */
.modal-cancel-btn {
  width: auto;
  height: 70rpx;           /* 高度变小 */
  line-height: 70rpx;      /* 文字垂直居中 */
  font-size: 28rpx;        /* 字体变小 */
  padding: 0 20rpx;        /* 减少左右内边距 */
  margin-top: 20rpx;       /* 和上面内容保持间距 */
  background: #f5f5f5;
  color: #666;
  border-radius: 8rpx;
  border: 1rpx solid #ddd;
  box-sizing: border-box;
}

/* 去掉小程序默认的 button 蓝色背景和边框（重要） */
.modal-cancel-btn::after {
  border: none;
}

.locate-mode-tip {
  position: fixed;
  top: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.7);
  color: white;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  z-index: 1000;
}

/* pages/map/map.wxss */

.locate-btn {
  position: fixed;
  right: 30rpx;
  bottom: 120rpx; /* 避开 tabBar 或底部操作栏 */
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.locate-icon {
  width: 48rpx;
  height: 48rpx;
}

