page {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #ffffff;
}

/* Navbar */
.navbar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.navbar .item {
  position: relative;
  flex: auto;
  text-align: center;
  line-height: 80rpx;
  color: #888;
  font-size: 32rpx;
}

.navbar .item.active {
  color: #cf1e1e;
}

.navbar .item.active::after {
  content: "";
  display: block;
  position: absolute;
  bottom: 10rpx;
  left: 40rpx;
  right: 40rpx;
  height: 4rpx;
  background: #cf1e1e;
}

/* Main content */
.content {
  flex: 1;
  padding: 0rpx 40rpx 40rpx;
  font-size: 32rpx;
  color: #333;
  text-align: left !important; /* 强制左对齐 */
}

/* Section */
.section {
  margin-bottom: 0rpx;
  text-align: left; /* 左对齐 */
}

/* Title 默认黑色 */
.title {
  font-weight: bold;
  font-size: 34rpx;
  margin-bottom: 12rpx;
  color: #333;
  text-align: center;
}

.guide-title {
  text-align: left;
  font-weight: bold;
  font-size: 34rpx;
  margin-top: 20rpx;
  margin-bottom: 12rpx;
  color: #333;
}
.divider {
  width: 100%;
  height: 1px;
  background-color: #eee;
  margin: 30rpx 0;
}
/* 禁止 = 红色 */
.forbid {
  color: #e74c3c;
}

/* 建议 = 绿色 */
.suggest {
  color: #27ae60;
}

.highlight {
  font-weight: bold;
  color: #333; 
}

/* 内容段落 */
.text {
  text-align: left; /* 强制左对齐 */
  color: #666;
}

.text view {
  margin-bottom: 12rpx;
  line-height: 1.6;
  text-align: left !important; /* view 内容强制左对齐 */
}

.img-aspect {
  width: 100%;
  padding-top: 43.05%; /* 551/1280 */
  position: relative;
  background-color: #f5f5f5; /* 加个浅灰背景，加载时更平滑 */
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
  border-radius: 16rpx;    /* ← 加圆角 */
  overflow: hidden; 
}

.img-content {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover; /* 保证图片铺满容器，不拉伸变形 */
}
/* 注释说明文字 */
.note {
  font-size: 28rpx;
  color: #777;
  margin-left: 16rpx;
  text-align: left !important;
}
.content,
.section,
.text,
.text view,
.note {
  text-align: left !important;
}
.bold {
  font-weight: 900;   
  color: #e74c3c;
}

/* 悬浮扭蛋机按钮 */
.floating-gacha-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx; /* 避开 tabBar 和 iPhone 底部安全区 */
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3); /* 半透明白色 */
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  color: #cf1e1e; /* 红色，和你的主题一致 */
  z-index: 999;
  backdrop-filter: blur(10rpx); /* 毛玻璃效果（可选） */
  -webkit-backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}