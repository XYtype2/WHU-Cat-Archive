/* pages/all/all.wxss */
.sub-navbar {
  display: flex;
  justify-content: space-around;
  align-items: center; 
  background-color: transparent; 
  padding: 0; 
  margin-top: -15px;  
}


.sub-item {
  font-size: 28rpx;
  color: #666;
  padding-bottom: 6rpx;
}
.sub-item.active {
  color: #cf1e1e;
  border-bottom: 3rpx solid #cf1e1e;
}

.back-to-top {
  position: fixed;
  right: 30rpx;
  bottom: 100rpx; 
  width: 80rpx;
  height: 80rpx;
  background-color: white;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
  z-index: 9999;
}

.arrow {
  font-size: 40rpx;
  color: rgb(94, 93, 93);
  line-height: 1;
}
  
/* 猫爪按钮样式 */
.paw-button {
  position: fixed;
  right: 30rpx;
  bottom: 200rpx; /* 根据需要调整位置 */
  width: 80rpx;
  height: 80rpx;
  background-color: white;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
  z-index: 9999;
  pointer-events: auto; 
}

.paw-icon {
  width: 52rpx;
  height: 52rpx;
  object-fit: contain;
}


/* 弹窗遮罩样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 10000;
}

/* 弹窗内容样式 */
.modal-content {
  background: white;
  width: 85%;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  text-align: left;
}
.modal-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 36rpx;
  color: #999;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.modal-close:hover {
  background-color: #f5f5f5;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 10rpx;
}

.modal-body {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.modal-confirm {
  margin-top: 40rpx;
  background-color: #ff6f61;
  color: white;
  border-radius: 50rpx;
  font-size: 28rpx;
}

.highlight {
  font-weight: bold;
  color :rgb(58, 57, 57)
}

.back-icon {
  width: 52rpx;
  height: 52rpx;

  display: block;

  object-fit: contain;   /* ⭐防止拉伸 */
}

.underline {
  text-decoration: underline;
  text-decoration-thickness: 2rpx; /* 可调 */
  text-underline-offset: 6rpx;     /* 小程序支持 */
}
/* 筛选容器（用于定位气泡和按钮） */
.filter-container {
  position: fixed;
  bottom: 300rpx;
  right: 30rpx;
  z-index: 9999;
}

/* 气泡提示 */
.filter-bubble {
  position: absolute;
  bottom: 100rpx; /* 气泡在按钮上方 */
  right: 20rpx;
  background-color: #666;       /* 灰色背景 */
  color: white;
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  transform: translateX(20%);   /* 向右偏移一半，让气泡居中对齐按钮 */
  opacity: 0.9;
  pointer-events: none;         /* 防止遮挡点击 */
}
/* 尖角三角（指向按钮） */
.filter-bubble::after {
  content: '';
  position: absolute;
  bottom: -12rpx;       /* 三角在气泡底部下方 */
  right: 55rpx;         /* 调整水平位置，对准按钮中心 */
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 12rpx solid #666; /* 与气泡背景色一致 */
}

/* 筛选按钮 */
.filter-btn {
  position: fixed;
  bottom: 300rpx; 
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: white;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
  z-index: 9999;
  pointer-events: auto; 
  color: rgb(65, 64, 64); /* 👈 文字灰色 */
  font-size: 24rpx; /* 可选：稍小一点更协调 */
  font-weight: bold; /* 确保不加粗 */
}

/* Location 弹窗 */
.modal-mask1 {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;

}

.location-modal {
  width: 100%;
  background: white;
  max-height: 60vh;
  padding: 30rpx;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  overflow-y: auto; /* 内容超出时可滚动 */
  -webkit-overflow-scrolling: touch; /* iOS 滚动更流畅 */
}

.modal-title1 {
  text-align: center;
  font-weight: bold;
  margin-bottom: 30rpx;
  font-size: 32rpx;
}

.location-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
  text-align: center;
  font-weight: normal; 
  font-size: 28rpx;
}

.location-item.active {
  color: #cf1e1e;
  font-weight: bold;
}

.back-icon1 {
  width: 24rpx;
  height: 28rpx;

  display: block;

  object-fit: contain; 
}